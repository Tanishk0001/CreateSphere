{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "lastLogin"]
    },
    "Project": {
      "title": "Project",
      "description": "Generated AI content project",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "video", "caption", "voice", "social"] },
        "name": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore server timestamp" },
        "imageUrl": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" },
        "audioUrl": { "type": "string", "format": "uri" },
        "result": { "type": "string" }
      },
      "required": ["type", "name", "createdAt"]
    },
    "SocialConnection": {
      "title": "SocialConnection",
      "description": "OAuth tokens for a social platform",
      "type": "object",
      "properties": {
        "platform": { "type": "string", "enum": ["instagram", "linkedin", "twitter", "youtube"] },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresAt": { "type": "number" },
        "profileName": { "type": "string" },
        "profileHandle": { "type": "string" },
        "profilePicture": { "type": "string", "format": "uri" },
        "updatedAt": { "type": "object" }
      },
      "required": ["platform", "accessToken", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "All content projects (filtered by userId in app)"
    },
    "/users/{userId}/socialConnections/{platform}": {
      "schema": "SocialConnection",
      "description": "User's connected social media accounts"
    }
  }
}
