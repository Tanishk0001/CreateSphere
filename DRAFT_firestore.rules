rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Mandatory Size Enforcements & 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'lastLogin']) &&
             data.keys().size() >= 2 && data.keys().size() <= 10 &&
             data.email is string && data.email.size() <= 256 &&
             data.lastLogin is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'status', 'createdAt']) &&
             data.keys().size() >= 5 && data.keys().size() <= 10 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.type in ['image', 'video', 'voice', 'caption', 'social'] &&
             data.status in ['completed', 'processing', 'failed', 'pending'] &&
             data.createdAt == request.time;
    }

    function isValidSocialConnection(data) {
      return data.keys().hasAll(['platform', 'accessToken', 'updatedAt']) &&
             data.platform in ['instagram', 'linkedin', 'twitter', 'youtube'] &&
             data.accessToken is string && data.accessToken.size() <= 2048 &&
             data.updatedAt == request.time;
    }

    // Rules for Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().email == existing().email;
    }

    // Rules for Projects (Top-level as per Dashboard.tsx usage)
    match /projects/{projectId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidProject(incoming());
      
      allow update: if isOwner(existing().userId) && isValidProject(incoming()) && (
        // Identity Integrity
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        // Action: Update Status or Results
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'imageUrl', 'videoUrl', 'audioUrl', 'result'])
      );
      
      allow delete: if isOwner(existing().userId);
    }

    // Rules for Social Connections (Subcollection)
    match /users/{userId}/socialConnections/{platform} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSocialConnection(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
