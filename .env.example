# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For deployment (e.g. Cloud Run), set this as an environment variable.
GEMINI_API_KEY="AIzaSyAwZT7MuxWlQ8vwKpip4MP7hnFiR1lWsRE"

# API_KEY: Used for high-quality video generation (Veo).
# In AI Studio, this is managed via the API Key Selection dialog.
# For standalone deployment, you can set this directly.
API_KEY="YOUR_PAID_PROJECT_API_KEY"

# OPENAI_API_KEY: Required for OpenAI video generation tasks.
# Set this in the Settings menu in AI Studio.
OPENAI_API_KEY="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"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
